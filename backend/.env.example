# ============================================================
#  TVTrack — Backend  (copie ce fichier en backend/.env)
# ============================================================

# Environnement : development en local, production sur l'hebergeur.
NODE_ENV=development

# Port d'ecoute (les hebergeurs comme Render fournissent leur propre PORT).
PORT=5000

# --- Base de donnees MongoDB ---
# Local (Docker)    : mongodb://127.0.0.1:27017/tvtrack
# Prod (MongoDB Atlas) : mongodb+srv://USER:MOTDEPASSE@cluster.xxxxx.mongodb.net/tvtrack
MONGODB_URI=mongodb://127.0.0.1:27017/tvtrack

# --- Authentification JWT ---
# Genere une cle FORTE (obligatoire en prod) :
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_this_secret_key
# Duree de validite des sessions : 7d, 24h, 30d...
JWT_EXPIRES_IN=7d

# --- CORS : URL(s) autorisee(s) du frontend, separees par des virgules ---
# Local : http://localhost:5173
# Prod  : https://ton-app.vercel.app
CORS_ORIGIN=http://localhost:5173

# --- API animes ---
# AniList ne demande AUCUNE cle : rien a configurer ici.

