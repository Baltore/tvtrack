# ============================================================
#  TVTrack — Frontend  (copie ce fichier en frontend/.env)
# ============================================================
#
# URL de base de TON backend, suffixee par /api, SANS slash final.
# Seules les variables prefixees VITE_ sont exposees au navigateur :
# ne mets JAMAIS de secret ici (pas de token, pas de mot de passe).
#
# Local : http://localhost:5000/api
# Prod  : https://ton-backend.onrender.com/api
VITE_API_URL=http://localhost:5000/api
